{
  "manifest_version": 3,
  "name": "Make it UST",
  "version": "0.2.0",
  "description": "Sign selected text as a UST (Universal State Transcript) — and verify any UST locally. LIGHT tier: proves the exact bytes, your key, and the time — not who you are or where it came from.",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Make it UST",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}